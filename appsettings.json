{
  "SmtpSender": {
    "LocalDomain": "mail.gsm.vin",
    "Port": 25,
    "EnableStartTls": true,
    "PreferIPv4": true,
    "AllowIPv6": false,
    "ConnectTimeoutMilliseconds": 10000,
    "CommandTimeoutMilliseconds": 30000,
    "NameServers": [ "8.8.8.8", "1.1.1.1" ]
  },
  "OutboundQueue": {
    "MaxAttempts": 8,
    "PollIntervalMilliseconds": 1000,
    "InitialRetryDelaySeconds": 30,
    "MaxRetryDelayMinutes": 30
  },
  "Dkim": {
    "Domain": "gsm.vin",
    "Selector": "mail",
    "PrivateKeyPath": "mail._domainkey.gsm.vin-private.pem",
    "AgentOrUserIdentifier": "@gsm.vin"
  }
}
